{
  "$id": "https://openminds.om-i.org/types/CustomAnatomicalEntity?format=json-schema",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": null,
  "properties": {
    "@id": {
      "description": "Metadata node identifier.",
      "type": "string"
    },
    "@type": {
      "const": "https://openminds.om-i.org/types/CustomAnatomicalEntity",
      "description": "Metadata schema identifier.",
      "type": "string"
    },
    "https://openminds.om-i.org/props/hasAnnotation": {
      "description": null,
      "items": {
        "$ref": "https://openminds.om-i.org/types/CustomAnnotation?format=json-schema",
        "type": "object"
      },
      "minItems": 1,
      "name": "hasAnnotation",
      "type": "array",
      "uniqueItems": true
    },
    "https://openminds.om-i.org/props/name": {
      "description": "Word or phrase that constitutes the distinctive designation of a being or thing.",
      "name": "name",
      "type": "string"
    },
    "https://openminds.om-i.org/props/relatedInterspeciesAnatomy": {
      "description": null,
      "else": {
        "properties": {
          "@id": {
            "format": "iri",
            "type": "string"
          }
        },
        "required": [
          "@id"
        ]
      },
      "if": {
        "required": [
          "@type"
        ]
      },
      "name": "relatedInterspeciesAnatomy",
      "then": {
        "properties": {
          "@id": {
            "format": "iri",
            "type": "string"
          },
          "@type": {
            "enum": [
              "https://openminds.om-i.org/types/AnatomicalCavity",
              "https://openminds.om-i.org/types/ExternalBodyRegion",
              "https://openminds.om-i.org/types/MuscularStructure",
              "https://openminds.om-i.org/types/NervousSystemStructure",
              "https://openminds.om-i.org/types/Organ",
              "https://openminds.om-i.org/types/OrganSystemStructure",
              "https://openminds.om-i.org/types/OrganismSubstance",
              "https://openminds.om-i.org/types/OrganismSystem",
              "https://openminds.om-i.org/types/SkeletalStructure",
              "https://openminds.om-i.org/types/TissueStructure",
              "https://openminds.om-i.org/types/VascularStructure"
            ],
            "format": "iri",
            "type": "string"
          }
        },
        "required": [
          "@id"
        ]
      },
      "type": "object"
    },
    "https://openminds.om-i.org/props/relationAssessment": {
      "description": null,
      "items": {
        "anyOf": [
          {
            "$ref": "https://openminds.om-i.org/types/QualitativeRelationAssessment?format=json-schema",
            "type": "object"
          },
          {
            "$ref": "https://openminds.om-i.org/types/QuantitativeRelationAssessment?format=json-schema",
            "type": "object"
          }
        ]
      },
      "minItems": 1,
      "name": "relationAssessment",
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "@id",
    "@type",
    "https://openminds.om-i.org/props/name"
  ],
  "title": "CustomAnatomicalEntity",
  "type": "object"
}