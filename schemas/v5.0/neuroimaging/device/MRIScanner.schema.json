{
  "$id": "https://openminds.om-i.org/types/MRIScanner?format=json-schema",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": null,
  "properties": {
    "@id": {
      "description": "Metadata node identifier.",
      "type": "string"
    },
    "@type": {
      "const": "https://openminds.om-i.org/types/MRIScanner",
      "description": "Metadata schema identifier.",
      "type": "string"
    },
    "https://openminds.om-i.org/props/contribution": {
      "description": null,
      "items": {
        "else": {
          "properties": {
            "@id": {
              "format": "iri",
              "type": "string"
            }
          },
          "required": [
            "@id"
          ]
        },
        "if": {
          "required": [
            "@type"
          ]
        },
        "then": {
          "properties": {
            "@id": {
              "format": "iri",
              "type": "string"
            },
            "@type": {
              "enum": [
                "https://openminds.om-i.org/types/Organization",
                "https://openminds.om-i.org/types/Person"
              ],
              "format": "iri",
              "type": "string"
            }
          },
          "required": [
            "@id"
          ]
        },
        "type": "object"
      },
      "minItems": 1,
      "name": "contribution",
      "type": "array",
      "uniqueItems": true
    },
    "https://openminds.om-i.org/props/description": {
      "description": "Longer statement or account giving the characteristics of someone or something.",
      "name": "description",
      "type": "string"
    },
    "https://openminds.om-i.org/props/internalIdentifier": {
      "description": "Term or code that identifies someone or something within a particular product.",
      "name": "internalIdentifier",
      "type": "string"
    },
    "https://openminds.om-i.org/props/magneticFieldStrength": {
      "$ref": "https://openminds.om-i.org/types/QuantitativeValue?format=json-schema",
      "description": null,
      "name": "magneticFieldStrength",
      "type": "object"
    },
    "https://openminds.om-i.org/props/name": {
      "description": "Word or phrase that constitutes the distinctive designation of a being or thing.",
      "name": "name",
      "type": "string"
    },
    "https://openminds.om-i.org/props/serialNumber": {
      "description": null,
      "name": "serialNumber",
      "type": "string"
    },
    "https://openminds.om-i.org/props/type": {
      "description": "Distinct class to which a group of entities or concepts with similar characteristics or attributes belong to.",
      "else": {
        "properties": {
          "@id": {
            "format": "iri",
            "type": "string"
          }
        },
        "required": [
          "@id"
        ]
      },
      "if": {
        "required": [
          "@type"
        ]
      },
      "name": "type",
      "then": {
        "properties": {
          "@id": {
            "format": "iri",
            "type": "string"
          },
          "@type": {
            "enum": [
              "https://openminds.om-i.org/types/DeviceType",
              "https://openminds.om-i.org/types/HardwareProduct"
            ],
            "format": "iri",
            "type": "string"
          }
        },
        "required": [
          "@id"
        ]
      },
      "type": "object"
    }
  },
  "required": [
    "@id",
    "@type",
    "https://openminds.om-i.org/props/contribution",
    "https://openminds.om-i.org/props/magneticFieldStrength",
    "https://openminds.om-i.org/props/name",
    "https://openminds.om-i.org/props/type"
  ],
  "title": "MRIScanner",
  "type": "object"
}